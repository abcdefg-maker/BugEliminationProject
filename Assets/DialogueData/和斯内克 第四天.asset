  m_Name: "\u548C\u65AF\u5185\u514B \u7B2C\u56DB\u5929"
  m_EditorClassIdentifier: 
  characterName: 
  characterSprite: {fileID: 0}
  sentences: []
  voiceClip: {fileID: 0}
  lines:
  - speakerName: "\u6CE2\u5495"
    text: "\u8001\u677F\uFF0C\u6211\u6709\u4E8B\u60F3\u95EE\u4F60"
    speakerPortrait: {fileID: 221768547408008743, guid: 2fe4b85907b523d48ba62a4b51fd1046, type: 3}
    voiceClip: {fileID: 8300000, guid: c4ed6840900d3104c8b138967975ba04, type: 3}
  - speakerName: "\u65AF\u5185\u514B"
    text: "\u2026\u2026"
    speakerPortrait: {fileID: 8325447771760189502, guid: 4b5de27edbee98e41ae3f41fb75b6692, type: 3}
    voiceClip: {fileID: 8300000, guid: 6ef5e86e06dcd944da38c3bb7da34301, type: 3}
  - speakerName: "\u65AF\u5185\u514B"
    text: "\uFF01\u4F60\u77E5\u9053\u4EC0\u4E48\u4E86\u2014\u2014\uFF08\u5C0F\u58F0\uFF09\u662F\u2026\u2026\u8FD8\u662F\u2026\u2026"
    speakerPortrait: {fileID: 8325447771760189502, guid: 4b5de27edbee98e41ae3f41fb75b6692, type: 3}
    voiceClip: {fileID: 8300000, guid: 4d56fd3adde2a2e4290eac082881ab8a, type: 3}
  - speakerName: "\u6CE2\u5495"
    text: "\u6628\u665A\u2026\u2026"
    speakerPortrait: {fileID: 221768547408008743, guid: 2fe4b85907b523d48ba62a4b51fd1046, type: 3}
    voiceClip: {fileID: 8300000, guid: c4ed6840900d3104c8b138967975ba04, type: 3}
  - speakerName: "\u65AF\u5185\u514B"
    text: "\u54E6\u5BB3\u8FD9\u4E2A\u554A\uFF0C\u662F\u8FD9\u6837\uFF0C\u6211\u4EEC\u90FD\u662Fbug\uFF0C\u7136\u540E\u5462\u665A\u4E0A\u90A3\u4E2A\u58F0\u97F3\u662F\u8981\u628A\u6211\u4EEC\u6E05\u9664\u2026\u2026"
    speakerPortrait: {fileID: 8325447771760189502, guid: 4b5de27edbee98e41ae3f41fb75b6692, type: 3}
    voiceClip: {fileID: 8300000, guid: d98b6e7240ac04b48aaa0a2b18b69368, type: 3}
  - speakerName: "\u6CE2\u5495"
    text: "\u7B49\u7B49\u7B49\u7B49\u7B49\u7B49\u7B49\u7B49\u7B49\u7B49\u4EC0\u4E48\u4E1C\u897F\uFF1F\uFF01"
    speakerPortrait: {fileID: -8218189810845437925, guid: 3c827efd65a704e4a972e7fab510b179, type: 3}
    voiceClip: {fileID: 8300000, guid: 3233e7abe9b1c1f44b7bc33088735f00, type: 3}
  - speakerName: "\u6CE2\u5495"
    text: "\u4EC0\u4E48\u662Fbug\uFF0Cbug\u662F\u4EC0\u4E48"
    speakerPortrait: {fileID: -8218189810845437925, guid: 3c827efd65a704e4a972e7fab510b179, type: 3}
    voiceClip: {fileID: 8300000, guid: 14c30980a07e0eb41ae7c7937fbf4556, type: 3}
  - speakerName: "\u65AF\u5185\u514B"
    text: "\u662F\u6211\u4EEC"
    speakerPortrait: {fileID: 8325447771760189502, guid: 4b5de27edbee98e41ae3f41fb75b6692, type: 3}
    voiceClip: {fileID: 8300000, guid: a137e106245597543a205307482ac4d9, type: 3}
  - speakerName: "\u65AF\u5185\u514B"
    text: "bug\u5C31\u662F\u6F0F\u6D1E\u662F\u5728\u786C\u4EF6\u8F6F\u4EF6\u534F\u8BAE\u7684\u5177\u4F53\u5B9E\u73B0\u6216\u7CFB\u7EDF\u5B89\u5168\u7B56\u7565\u4E0A\u5B58\u5728\u7684\u7F3A\u9677\u4ECE\u800C\u53EF\u4EE5\u4F7F\u653B\u51FB\u8005\u80FD\u591F\u5728\u672A\u6388\u6743\u7684\u60C5\u51B5\u4E0B\u8BBF\u95EE\u6216\u7834\u574F\u7CFB\u7EDF\u2026\u2026"
    speakerPortrait: {fileID: 8325447771760189502, guid: 4b5de27edbee98e41ae3f41fb75b6692, type: 3}
    voiceClip: {fileID: 8300000, guid: 732b218e3bfba5b49a8d36b1eaa183c1, type: 3}
  - speakerName: "\u6CE2\u5495"
    text: "\u505C\u505C\u505C\u505C\u505C"
    speakerPortrait: {fileID: -8218189810845437925, guid: 3c827efd65a704e4a972e7fab510b179, type: 3}
    voiceClip: {fileID: 8300000, guid: 48dc908877b0fa94e9eeb112dfee4714, type: 3}
  - speakerName: "\u6CE2\u5495"
    text: "\u5C31\u662F\u7F3A\u9677\u7684\u610F\u601D\uFF1F"
    speakerPortrait: {fileID: -8218189810845437925, guid: 3c827efd65a704e4a972e7fab510b179, type: 3}
    voiceClip: {fileID: 8300000, guid: c4ed6840900d3104c8b138967975ba04, type: 3}
  - speakerName: "\u65AF\u5185\u514B"
    text: "\u4F60\u8981\u60F3\u8FD9\u4E48\u7406\u89E3\u5012\u4E5F\u6CA1\u95EE\u9898\uFF0C\u6CA1\u770B\u51FA\u6765\u6211\u4EEC\u90FD\u957F\u5F97\u4E0D\u592A\u5BFB\u5E38\u5417\uFF0C\u4F60\u4ECE\u5C0F\u5230\u5927\u6CA1\u6709\u6000\u7591\u8FC7\uFF1F"
    speakerPortrait: {fileID: 8325447771760189502, guid: 4b5de27edbee98e41ae3f41fb75b6692, type: 3}
    voiceClip: {fileID: 8300000, guid: 732b218e3bfba5b49a8d36b1eaa183c1, type: 3}
  - speakerName: "\u6CE2\u5495"
    text: "\u989D\u2026\u2026"
    speakerPortrait: {fileID: -8218189810845437925, guid: 3c827efd65a704e4a972e7fab510b179, type: 3}
    voiceClip: {fileID: 8300000, guid: c019a00d5b9262147819a6ff2fd31e17, type: 3}
  - speakerName: "\u65AF\u5185\u514B"
    text: "\u603B\u4E4B\uFF0C\u867D\u7136\u5F88\u4E0D\u60F3\u627F\u8BA4\uFF0C\u4F46\u6211\u4EEC\u672C\u8EAB\u5927\u6982\u5C31\u662F\u2014\u2014\u201Cbug\u201D\uFF0C\u6211\u4EEC\u7684\u5B58\u5728\u672C\u8EAB\u5C31\u662F\u94BB\u4E86\u7A7A\u5B50"
    speakerPortrait: {fileID: 8325447771760189502, guid: 4b5de27edbee98e41ae3f41fb75b6692, type: 3}
    voiceClip: {fileID: 8300000, guid: 732b218e3bfba5b49a8d36b1eaa183c1, type: 3}
  - speakerName: "\u6CE2\u5495"
    text: "\u90A3\u5DE5\u4F5C\u2026\u2026"
    speakerPortrait: {fileID: -8218189810845437925, guid: 3c827efd65a704e4a972e7fab510b179, type: 3}
    voiceClip: {fileID: 8300000, guid: ddde0139f867e0943a95b789e87e5deb, type: 3}
  - speakerName: "\u65AF\u5185\u514B"
    text: "\u603B\u5F97\u7ED9\u5927\u5BB6\u627E\u70B9\u6D3B\u5E72\u5427\uFF0C\u4E0D\u7136\u600E\u4E48\u7EF4\u6301\u793E\u4F1A\u8FD0\u8F6C\u5462\uFF1F\u4E0D\u80FD\u56E0\u4E3A\u6211\u4EEC\u662F\u201Cbug\u201D\u5C31\u60F6\u60F6\u4E0D\u53EF\u7EC8\u65E5\u4E86\uFF0C\u8FD9\u662F\u672C\u86C7\u521B\u529E\u516C\u53F8\u7684\u7406\u5FF5"
    speakerPortrait: {fileID: 8325447771760189502, guid: 4b5de27edbee98e41ae3f41fb75b6692, type: 3}
    voiceClip: {fileID: 8300000, guid: 732b218e3bfba5b49a8d36b1eaa183c1, type: 3}
  - speakerName: "\u6CE2\u5495"
    text: "\u6240\u4EE5\uFF0C\u6211\u4EEC\u7684\u5B58\u5728\u6BEB\u65E0\u610F\u4E49\u5417\uFF1F\u6240\u6709\u4EBA\u90FD\u77E5\u9053\u5417\uFF1F\u77E5\u9053\u81EA\u5DF1\u6D3B\u7684\u53EA\u662F\u4E2A\u2026\u2026\u8BEF\u4F1A\uFF1F"
    speakerPortrait: {fileID: -8218189810845437925, guid: 3c827efd65a704e4a972e7fab510b179, type: 3}
    voiceClip: {fileID: 8300000, guid: a55e366519816fe4699ede1a2c4fcf15, type: 3}
  - speakerName: "\u65AF\u5185\u514B"
    text: "\u8FD8\u5F97\u4E86\uFF1F\u4F60\u662F\u56E0\u4E3A\u4E00\u4E2A\u610F\u5916\u624D\u77E5\u9053\u7684\uFF0C\u5927\u90E8\u5206\u5BB6\u4F19\u4E00\u751F\u90FD\u4E0D\u4F1A\u77E5\u9053\u81EA\u5DF1\u662F\u4E2Abug\uFF0C\u4E0D\u8FC7\u53EA\u8981\u5B83\u4EEC\u4E0D\u77E5\u9053\uFF0C\u8FD9\u4EF6\u4E8B\u5BF9\u5B83\u4EEC\u800C\u8A00\u4E5F\u5C31\u4E0D\u91CD\u8981\u4E86"
    speakerPortrait: {fileID: 8325447771760189502, guid: 4b5de27edbee98e41ae3f41fb75b6692, type: 3}
    voiceClip: {fileID: 8300000, guid: 732b218e3bfba5b49a8d36b1eaa183c1, type: 3}
  - speakerName: "\u65AF\u5185\u514B"
    text: "\u4F46\u4F60\u90FD\u77E5\u9053\u4E86\uFF0C\u4F60\u7684\u4E16\u754C\u5C31\u4F1A\u53D8\u7684\u4E0D\u540C\u4E86\u3002\u4F60\u9700\u8981\u65F6\u95F4\u5B69\u5B50\uFF0C\u8FC7\u4E00\u6BB5\u65F6\u95F4\uFF0C\u4F60\u5C31\u4F1A\u9002\u5E94\u4E86"
    speakerPortrait: {fileID: 8325447771760189502, guid: 4b5de27edbee98e41ae3f41fb75b6692, type: 3}
    voiceClip: {fileID: 8300000, guid: d98b6e7240ac04b48aaa0a2b18b69368, type: 3}
  - speakerName: "\u65C1\u767D"
    text: "\u3010\u56DE\u5230\u529E\u516C\u5BA4\u53BB\u627E\u6C6A\uFF1F\u3011"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
