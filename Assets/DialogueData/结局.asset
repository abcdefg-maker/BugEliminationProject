%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ff45d1b559b33be46bd69a25b82ab052, type: 3}
  m_Name: "\u7ED3\u5C40"
  m_EditorClassIdentifier: 
  characterName: 
  characterSprite: {fileID: 0}
  sentences: []
  voiceClip: {fileID: 0}
  lines:
  - speakerName: 
    text: "\u5510\u51E1\uFF1A\u600E\u4E48\u53C8\u8981\u4FEEbug\u554A"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1A\u70E6\u6B7B\u4E86"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u6BDB\u7814\u7814\uFF1A\u4E0D\u662F\u4FEE\u4E86\u4E0D\u5C11\u5417"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1A\u8FD9\u4E1C\u897F\u50CF\u5728\u4E0D\u505C\u7E41\u6B96\uFF0C\u8D8A\u6765\u8D8A\u591A\uFF0C\u5230\u5E95\u641E\u6BDB\u554A\uFF01"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1A\u6211\u7684\u6E38\u620F\u7406\u60F3\uFF0C\u6211\u7684\u4F1F\u5927\u5B8F\u56FE\uFF0C\u90FD\u65AD\u9001\u5728\u8FD9\u4E9B\u7E41\u7410\u7684\u5DE5\u4F5C\u91CC\u4E86"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u6BDB\u7814\u7814\uFF1A\u2026\u2026\u561B\uFF0C\u6CBB\u5927\u56FD\u82E5\u70F9\u5C0F\u9C9C\uFF0C\u6210\u5927\u4E8B\u5FC5\u62D8\u5C0F\u8282\u561B"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1A\u5509\uFF0C\u7B97\u4E86\uFF0C\u8FD8\u662F\u4FEE\u5427"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u6BDB\u7814\u7814\uFF1A\u6709\u4EC0\u4E48\u56F0\u96BE\u5417\uFF0C\u6211\u770B\u8FD9\u90FD\u5904\u7406\u7684\u5DEE\u4E0D\u591A\u4E86\u554A"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u6BDB\u7814\u7814\uFF1A\u8BF6\uFF0C\u7B49\u7B49\uFF0C\u4F60\u770B\u8FD9\u4E00\u4E32\u4EE3\u7801\uFF0C\u597D\u50CF\u6709\u70B9\u4E0D\u4E00\u6837\uFF0C\u4F60\u771F\u5199\u8FC7\u8FD9\u4E1C\u897F\u5417\uFF1F"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1A\u4E0D\u4E00\u6837\u2026\u2026\uFF1F"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1A\u2026\u2026\u8BF6\uFF0C\u771F\u7684\u8BF6\u2026\u2026"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u6BDB\u7814\u7814\uFF1A\u6709\u70B9\u610F\u601D\uFF0C\u8BF6\uFF0C\u4F60\u4E0D\u89C9\u5F97\u8DDF\u54B1\u5927\u5B66\u7B2C\u4E00\u6B21\u505A\u7684\u6E38\u620Fdemo\u91CC\r\n\u90A3\u4E2A\u4E1C\u897F\u6709\u70B9\u50CF\u5417\uFF1F\u4F60\u770B\u4F60\u770B"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1Aos\uFF1A\u2026\u2026\u662F\u2026\u2026\u5417\uFF0C\u5927\u5B66\uFF1F\u597D\u9065\u8FDC\u554A\u2026\u2026\u660E\u660E\u6CA1\u8FC7\u53BB\u591A\u4E45\uFF0C\u90A3\r\n\u79CD\u751F\u6D3B\u5374\u597D\u50CF\u79BB\u81EA\u5DF1\u5F88\u8FDC\u4E86"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1Aos\uFF1A\u660E\u660E\u4E00\u76F4\u4EE5\u6765\u90FD\u671D\u7740\u65E2\u5B9A\u7684\u76EE\u6807\uFF0C\u5411\u7740\u7406\u60F3\u7684\u65B9\u5411\u524D\u8FDB\u3002\r\n\u4E00\u5230\u5DE5\u4F5C\u4E0A\uFF0C\u5374\u53C8\u5C61\u5C61\u78B0\u58C1\uFF0C\u597D\u4E0D\u5BB9\u6613\u6765\u5230\u73B0\u5728\u7684\u516C\u53F8\uFF0C\u603B\u662F\u529D\u81EA\u5DF1\r\n\u8FD9\u4E5F\u4E0D\u9519\u4E86\uFF0C\u5916\u9762\u627E\u4E0D\u5230\u5DE5\u4F5C\u7684\u5927\u6709\u4EBA\u5728\uFF0C\u5374\u4E5F\u53EA\u662F\u5728\u505A\u8FD9\u6837\u7684\u5DE5\u4F5C"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1Aos\uFF1A\u8FD9\u4E9B\u5DE5\u4F5C\u7684\u610F\u4E49\u5230\u5E95\u662F\u4EC0\u4E48\u5462\uFF1F"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1Aos\uFF1A\u4ECE\u4EC0\u4E48\u65F6\u5019\u5F00\u59CB\u3002\u8FDE\u6211\u81EA\u5DF1\u90FD\u8D8A\u6765\u8D8A\u4E0D\u76F8\u4FE1\u81EA\u5DF1\u7684\u90A3\u4E9B\u4EC0\r\n\u4E48\u201C\u6E38\u620F\u7406\u60F3\u201D\u4E86\u5462"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1Aos\uFF1Abug\u2026\u2026bug\u2026\u2026\u6211\u7684\u4EBA\u751F\u600E\u4E48\u4E5F\u8D8A\u8FC7\u8D8A\u50CF\u4E00\u573Abug\uFF1F\u8981\u662F\u80FD\u4FEE\u590D\u6211\u4EBA\u751F\u7684bug\u90A3\u5C31\u597D\u4E86\uFF0C\u8981\u662F\u4E00\u5207\u90FD\u80FD\u50CFbug\u4E00\u6837\u80FD\u88AB\u8FD9\u6837\u8F7B\u6613\u89E3\u51B3\u5C31\u597D\u4E86\u2026\u2026\r\n\u2026\u2026"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u6BDB\u7814\u7814\uFF1A\u6211\u4E0D\u5F00\u73A9\u7B11\uFF0C\u8FD9\u4E2A\u201Cbug\u201D\u771F\u7684\u5F88\u773C\u719F\u2026\u2026\u4F60\u770B\u2026\u2026\u53EA\u9700\u8981\u628A\u5B83\u8FD9\u6837\u5BFC\u51FA\u6765\uFF0C\u800C\u4E14\u8FD9\u66F4\u50CF\u2026\u2026"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u4F60\u7A81\u7136\u72B9\u8C6B\u4E86\uFF0C\u624B\u6307\u505C\u5728\u952E\u76D8\u4E0A\u3002\u4F60\u770B\u89C1\u540C\u4E8B\u9976\u6709\u5174\u8DA3\u5730\u6572\u51FB\u7740\uFF0C\u4F60\u5C1D\u8BD5\u7167\u4ED6\u8BF4\u7684\u505A\uFF0C\u63D0\u53D6\u90A3\u4E32\u201Cbug\u201D"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5947\u602A\u7684\u662F\uFF0C\u4ED4\u7EC6\u770B\u53BB\uFF0C\u8FD9\u786E\u5B9E\u4E0D\u53EA\u50CF\u4E2A\u201Cbug\u201D\uFF0C\u800C\u662F\u4E00\u4E9B\u66F4\u590D\u6742\u7684\u4E1C\u897F\uFF0C\u7535\u8111\u5F00\u59CB\u8F6C\u5708\u5708\u2026\u2026"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5C4F\u5E55\u4E0A\u7A81\u7136\u51FA\u73B0\u4E86\u4E00\u53EA\u957F\u4E86\u7F8A\u89D2\u7684\u5947\u602A\u7684\u4E4C\u9E26\u5728\u539F\u5730\u65CB\u8F6C"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u6BDB\u7814\u7814\uFF1A\u5929\u554A\uFF01\u6CE2\u5495\uFF01\u5B83\u600E\u4E48\u4F1A\u5728\u8FD9\u91CC"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1A\u2026\u2026\uFF01"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1A\u6211\uFF0C\u6211\u4E0D\u77E5\u9053\uFF0C\u6211\u4E0D\u77E5\u9053\u4E3A\u4EC0\u4E48\u4F1A\u2026\u2026\u8FD9\u6839\u672C\u4E0D\u53EF\u80FD\uFF0C\u8FD9\u91CC\u600E\u4E48\u53EF\u80FD\u51FA\u73B0\u4E00\u5F20\u8D34\u56FE\uFF1F\uFF1F\uFF1F"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u6BDB\u7814\u7814\uFF1A\u4F60\u8FD8\u8BB0\u5F97\u5417\uFF0C\u8FD9\u662F\u6CE2\u5495\u554A\uFF01"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1A\u2026\u2026\u597D\u50CF\u662F\u6211\u4EEC\u4E0A\u5927\u5B66\u65F6\u7B2C\u4E00\u6B21\u505A\u6E38\u620F\u7528\u7684\u7D20\u6750\uFF1F"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u6BDB\u7814\u7814\uFF1A\u5BF9\u5440\uFF01\u77A7\u4F60\u8FD9\u53CD\u5E94\uFF0C\u6211\u90FD\u4EE5\u4E3A\u4F60\u5FD8\u4E86\u3002\u90A3\u4E2A\u65F6\u5019\u6211\u4EEC\u8FD8\u5565\u90FD\u4E0D\u61C2\uFF0C\u6280\u672F\u529B\u4E5F\u8FDC\u8FDC\u6CA1\u6709\u73B0\u5728\u9AD8\uFF0C\u62A5\u540D\u4E2A\u6BD4\u8D5B\u8FDEddl\u90FD\u8981\u8D76\u4E0D\u4E0A\uFF0C\u4E5F\u5B9E\u73B0\u4E0D\u4E86\u592A\u591A\u60F3\u6CD5\uFF0C\u53EA\u80FD\u4F18\u5316\u4F18\u5316\u518D\u4F18\u5316"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u6BDB\u7814\u7814\uFF1A\u53EF\u662F\uFF0C\u90A3\u4E2A\u65F6\u5019\u771F\u7684\u89C9\u5F97\u5F88\u5F00\u5FC3\u5427"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u6BDB\u7814\u7814\uFF1A\u770B\u89C1\u81EA\u5DF1\u5199\u7684\uFF0C\u753B\u7684\uFF0C\u7F16\u7684\u4E1C\u897F\u771F\u7684\u5728\u50CF\u6211\u4EEC\u5BF9\u201C\u6E38\u620F\u201D\u7684\u8BA4\u77E5\u4E00\u6837\u884C\u52A8"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u6BDB\u7814\u7814\uFF1A\u53EA\u8981\u611F\u53D7\u5230\u4E00\u6B21\u90A3\u79CD\u611F\u89C9\uFF0C\u53EF\u80FD\u771F\u7684\u4F1A\u6C89\u8FF7\u5176\u4E2D\u5427"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1A\u2026\u2026\u8FD9\u53EF\u771F\u662F"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u6CE2\u5495\u53EA\u662F\u65CB\u8F6C"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u5510\u51E1\uFF1A\u6211\u600E\u4E48\u53EF\u80FD\u4F1A\u5FD8\u5462"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u4F60\u4EEC\u4E92\u76F8\u5BF9\u89C6\uFF0C\u90FD\u54C8\u54C8\u5927\u7B11\u8D77\u6765\uFF0C\u597D\u50CF\u627E\u56DE\u4E86\u81EA\u5DF1\u7B2C\u4E00\u6B21\u6572\u4E0B\u4E00\u884C\u4EE3\u7801\uFF0C\u8DD1\u51FA\u4E00\u4E2A\u7A0B\u5E8F\uFF0C\u642D\u5EFA\u7D20\u6750\u62FC\u51D1\u51FA\u4E00\u4E2A\u201C\u6E38\u620F\u201D\u7684\u5FEB\u4E50"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u8FD9\u4EFD\u5FEB\u4E50\uFF0C\u65E0\u8BBA\u600E\u4E48\u6837\uFF0C\u90FD\u4E0D\u4F1A\u4ECE\u4F60\u4EEC\u7684\u751F\u547D\u4F53\u9A8C\u4E2D\u6D41\u901D\r\n\u800C\u53EA\u8981\u8BB0\u7740\u6709\u8FC7\u8FD9\u6837\u7684\u611F\u89C9\uFF0C\u4E00\u5207\u7684\u8FFD\u5BFB\u548C\u53D8\u5316\uFF0C\u53C8\u600E\u4E48\u4F1A\u6BEB\u65E0\u610F\u4E49\u5462"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  - speakerName: 
    text: "\u8FBE\u6210\u7ED3\u5C40\uFF1A\u201C\u610F\u4E49\u201D\u5C31\u5728\u4F60\u8EAB\u8FB9"
    speakerPortrait: {fileID: 0}
    voiceClip: {fileID: 0}
  flagsToSet:
  - Thanks
  flagsToRemove: []
